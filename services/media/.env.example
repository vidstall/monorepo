# Shared LiveKit/Redis cluster
REDIS_HOST=redis.internal:6379
REDIS_PASSWORD=
XAISEN_AUTO_CLUSTER_KEY=true

# On-chain media identity. The node must be registered and approved as ROLE_SFU.
XAISEN_MEDIA_NODE_ID=
XAISEN_CLUSTER_ID=
XAISEN_LIVEKIT_URL=wss://media.example.com
XAISEN_MEDIA_KEY_PATH=/var/lib/xaisen/media-x25519.key

# Public broker and Sui verification
XAISEN_BROKER_ADDR=:7890
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
CONTRACT_PACKAGE_ID=
