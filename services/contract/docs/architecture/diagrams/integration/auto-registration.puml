@startuml
' Generated: 2026-03-07 | Phase: 3 | Status: AS-BUILT
title Auto-Registration Flow (Daemon -> Chain)

participant "Daemon\n(CP or Validator)" as daemon
participant "Sui Chain\n(registration)" as reg
participant "Sui Chain\n(role-specific registry)" as rreg

== Step 1: Miner Registration ==

daemon -> reg : registration::register(\n  networkRegistry, minerStore,\n  stakeCoin, endpoint, strength)
activate reg

reg -> reg : determine_role from stake amount
reg -> reg : create MinerProfile + StakePosition

alt CP role
  reg --> daemon : ControlPlaneCap + StakePosition
else Validator role
  reg --> daemon : MinerCap + StakePosition
end

reg --> daemon : emit MinerRegistered
deactivate reg

daemon -> daemon : extract object IDs from TX effects

== Step 2: Role-Specific Registration ==

alt CP Daemon
  daemon -> rreg : control_plane_registry::register_cp(\n  networkRegistry, cpRegistry,\n  cpCap, stakePosition)
  rreg --> daemon : emit CPRegistered
else Validator Daemon
  daemon -> rreg : validator_registry::register_validator(\n  networkRegistry, validatorRegistry,\n  minerCap, stakePosition)
  rreg --> daemon : emit ValidatorRegistered
end

note right of daemon
  After registration:
  - Log cap ID for .env persistence
  - On next startup, skip if cap ID in env
end note

@enduml
