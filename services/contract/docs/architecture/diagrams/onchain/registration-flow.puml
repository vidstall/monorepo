@startuml
' Generated: 2026-03-07 | Phase: 1-2 | Status: AS-BUILT
title Miner Registration Flow

actor "Miner Wallet" as miner
participant "Sui Chain\n(registration)" as chain
participant "Sui Chain\n(staking)" as staking
participant "Sui Chain\n(caps)" as caps

miner -> chain : register(registry, store, coin, ip, port, region, ...)
activate chain

chain -> chain : assert !is_paused(registry)
chain -> staking : determine_role(coin_value, registry)
staking --> chain : role (CP / Relay / Validator / User)

chain -> staking : create(owner, miner_id, role, coin)
staking --> chain : StakePosition

chain -> staking : transfer_to(stake_pos, sender)
note right: StakePosition transferred\nto miner wallet

alt role == CP
  chain -> caps : new_cp_cap(miner_id)
  caps --> chain : ControlPlaneCap
else role != CP
  chain -> caps : new_miner_cap(miner_id, role)
  caps --> chain : MinerCap
end

chain --> miner : emit MinerRegistered event
deactivate chain

@enduml
