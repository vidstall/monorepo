@startuml
' Generated: 2026-03-07 | Phase: 2 | Status: AS-BUILT
title Room Lifecycle

actor "User" as user
participant "Sui Chain\n(room_manager)" as room
participant "Sui Chain\n(user_registry)" as ureg

== Create Room ==

user -> room : create_room(net_reg, manager, user_reg, relay_mode)
activate room

room -> room : assert !is_paused
room -> room : assert relay_mode is SFU or MCU
room -> ureg : is_registered(user_reg, sender)
ureg --> room : true

room -> room : generate room_id\n(object::new + uid_to_inner + delete)
room -> room : add RoomInfo(status=PENDING)
room -> ureg : increment_room_count(user_reg, sender)
room --> user : emit RoomCreated(room_id, creator, relay_mode)

deactivate room

note right of room
  Status transitions (Phase 3+):
  PENDING -> READY -> ACTIVE -> CLOSED
  set_room_status() is public(package)
end note

== Close Room ==

user -> room : close_room(net_reg, manager, room_id)
activate room

room -> room : assert !is_paused
room -> room : assert sender == creator
room -> room : assert status != CLOSED
room -> room : set status = CLOSED, active_count--
room --> user : emit RoomClosed(room_id, closed_by, epoch)

deactivate room

@enduml
