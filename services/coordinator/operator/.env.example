# 1. Copy this file and rename it to .env.local (for local dev) or wire the
#    same variables into your deployment's env (see docker-compose.yml).

# COORDINATOR SELF-REGISTRATION (on-chain worker discovery)
# This sidecar registers the coordinator on-chain as a ROLE_COORDINATOR worker
# on first boot - registration + heartbeat only, presence/observability, not
# a trust gate anything currently checks. It generates and persists its own
# Sui keypair locally the first time it runs (see COORDINATOR_OPERATOR_KEY_PATH)
# - fund that address with enough SUI for gas + the worker stake (devnet: use
# the Sui devnet faucet) before starting.

# Contract identity (same convention as services/routes and services/media).
CONTRACT_ENV_PATH=
CONTRACT_NETWORK=
CONTRACT_PACKAGE_ID=
CONTRACT_REGISTRY_OBJECT_ID=

# Internal (non-public) address this coordinator is reachable at, e.g. the
# Docker Compose service DNS name. Never a public URL - Redis must stay
# private (see README.md). Published on-chain as the worker's metadata_uri
# and node profile broker_endpoint, informational only.
COORDINATOR_INTERNAL_ADDRESS=redis:6379

# Optional: override where the generated operator keypair + node_id are
# persisted. Defaults to runtime/coordinator/<COORDINATOR_INSTANCE_NAME or
# "default">.json at the repo root.
COORDINATOR_OPERATOR_KEY_PATH=
COORDINATOR_INSTANCE_NAME=
# Optional: how often (ms) to send an on-chain heartbeat to prove liveness.
# Default 5 min.
COORDINATOR_HEARTBEAT_INTERVAL_MS=
# Optional: node profile region label.
COORDINATOR_REGION=
# Optional: placeholder rental price / stake for self-registration (in MIST).
# Defaults are fine - coordinator is never hired via the rental flow.
COORDINATOR_PRICE_PER_RENTAL_MIST=
COORDINATOR_STAKE_MIST=
# Set to "true" to disable self-registration entirely (e.g. local dev without
# a funded wallet).
COORDINATOR_DISABLE_SELF_REGISTRATION=
