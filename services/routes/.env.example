# 1. Copy this file and rename it to .env.local
# 2. Update the enviroment variables below.

# REQUIRED SETTINGS
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Optional legacy fallback for rooms without a routed rental. Routed rooms
# discover media clusters on-chain and do not use a shared LiveKit secret.
LIVEKIT_URL=

# OPTIONAL SETTINGS
S3_KEY_ID=
S3_KEY_SECRET=
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=

# ROUTES SELF-REGISTRATION (on-chain worker discovery)
# This route registers itself on-chain as a ROLE_ROUTER worker on first boot, so the
# frontend can discover it. It generates and persists its own Sui keypair locally the
# first time it runs (see ROUTES_OPERATOR_KEY_PATH) - fund that address with enough
# SUI for gas + the worker stake (devnet: use the Sui devnet faucet) before starting.
#
# Public URL this route is reachable at (used as the on-chain worker's metadata_uri).
ROUTES_PUBLIC_URL=
# Optional: override where the generated operator keypair + node_id are persisted.
# Defaults to runtime/routes/<ROUTES_INSTANCE_NAME or "default">.json at the repo root.
ROUTES_OPERATOR_KEY_PATH=
ROUTES_INSTANCE_NAME=
# Optional: how often (ms) to send an on-chain heartbeat to prove liveness. Default 5 min.
ROUTES_HEARTBEAT_INTERVAL_MS=
# Optional: placeholder rental price / stake for self-registration (in MIST). Defaults
# are fine for a router that isn't meant to be hired via the rental flow.
ROUTES_PRICE_PER_RENTAL_MIST=
ROUTES_STAKE_MIST=
# Set to "true" to disable self-registration entirely (e.g. local dev without a funded wallet).
ROUTES_DISABLE_SELF_REGISTRATION=
